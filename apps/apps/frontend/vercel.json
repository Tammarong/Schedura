{
  "version": 2,
  "rewrites": [
    { "source": "/api/:match*", "destination": "https://schedura-be.onrender.com/api/:match*" },
    { "source": "/socket.io", "destination": "https://schedura-be.onrender.com/socket.io" },
    { "source": "/socket.io/:match*", "destination": "https://schedura-be.onrender.com/socket.io/:match*" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/og-image.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type",  "value": "image/png" }
      ]
    }
  ]
}
